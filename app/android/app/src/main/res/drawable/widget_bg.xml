<?xml version="1.0" encoding="utf-8"?>
<!-- Фон виджета: скруглённая карточка с тонкой границей.
     Цвет задаётся динамически через setInt(...setColorFilter) из KaizenWidgetProvider.
     Дефолтные значения = тема Focus (surface #241D11, border #3A3020). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#241D11" />
    <corners android:radius="24dp" />
    <stroke android:width="1dp" android:color="#3A3020" />
</shape>
