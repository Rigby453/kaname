<?xml version="1.0" encoding="utf-8"?>
<!--
    Средний виджет 4×2: 2 ближайших пункта + X/Y главных + стрик + Kai справа-сверху.
    Kai выглядывает из верхнего правого угла, не перекрывая текст задач.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root_medium"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Основной контент -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp"
        android:paddingEnd="60dp">

        <!-- Заголовок: «Дальше» + стрик -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Up next"
                android:textSize="11sp"
                android:textColor="#9E9070"
                android:textAllCaps="true"
                android:letterSpacing="0.08" />

            <!-- Стрик нейтральным цветом -->
            <TextView
                android:id="@+id/medium_streak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0d"
                android:textSize="11sp"
                android:textColor="#9E9070" />

        </LinearLayout>

        <!-- Пункт 1 -->
        <LinearLayout
            android:id="@+id/medium_row1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/medium_time1"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#F6EFE1"
                android:maxLines="1" />

            <TextView
                android:id="@+id/medium_icon1"
                android:layout_width="18dp"
                android:layout_height="wrap_content"
                android:text="•"
                android:textSize="12sp"
                android:textColor="#9E9070"
                android:gravity="center" />

            <TextView
                android:id="@+id/medium_title1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textSize="14sp"
                android:textColor="#F6EFE1"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#3A3020"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp" />

        <!-- Пункт 2 -->
        <LinearLayout
            android:id="@+id/medium_row2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/medium_time2"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#F6EFE1"
                android:maxLines="1" />

            <TextView
                android:id="@+id/medium_icon2"
                android:layout_width="18dp"
                android:layout_height="wrap_content"
                android:text="•"
                android:textSize="12sp"
                android:textColor="#9E9070"
                android:gravity="center" />

            <TextView
                android:id="@+id/medium_title2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textSize="14sp"
                android:textColor="#F6EFE1"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Нижняя строка: X/Y главных -->
        <TextView
            android:id="@+id/medium_main_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="0/0 main"
            android:textSize="11sp"
            android:textColor="#F6EFE1" />

    </LinearLayout>

    <!-- Kai выглядывает из верхнего правого угла (peek) -->
    <ImageView
        android:id="@+id/kai_image_medium"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-10dp"
        android:layout_marginEnd="-10dp"
        android:scaleType="fitCenter"
        android:src="@drawable/kai_neutral"
        android:contentDescription="Kai" />

</FrameLayout>
