<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Локальные уведомления (напоминания о разборе). Android 13+ требует runtime-разрешение. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Точные будильники (Android 12+/API 31+): нужны для пробивания Doze-режима.
         На Android 14+ требует явного согласия пользователя через системные настройки
         (requestExactAlarmsPermission). Без этого разрешения сервис откатывается на
         inexactAllowWhileIdle — уведомления приходят, но с опозданием. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <!-- Перепланирование уведомлений после перезагрузки устройства.
         Receiver (ScheduledNotificationBootReceiver) ниже получает BOOT_COMPLETED
         и вызывает rescheduleNotifications() из плагина. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- Доступ к статистике использования (Screen Time, реальный трекинг). Спец-разрешение,
         выдаётся пользователем в системных настройках «Доступ к данным об использовании». -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions"/>
    <!-- Голосовой ввод еды (speech_to_text, SPEC C5) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <!-- Сканер штрихкодов и фото еды (mobile_scanner / image_picker) -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <application
        android:label="Kaizen"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- flutter_local_notifications: receiver для срабатывания отложенных уведомлений.
             Без него zonedSchedule не отобразит уведомление на Android. -->
        <receiver
            android:exported="false"
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver" />
        <!-- flutter_local_notifications: перепланирование уведомлений ТОЛЬКО после reboot.
             Получает BOOT_COMPLETED/QUICKBOOT и вызывает FlutterLocalNotificationsPlugin.rescheduleNotifications().
             ВАЖНО: MY_PACKAGE_REPLACED намеренно НЕ слушаем — при переустановке/обновлении плагин
             проигрывал бы кэш просроченных сегодня слотов (залп уведомлений сразу после установки).
             Приложение и так перепланирует все напоминания при старте (rescheduleAllReminders + вода + привычки),
             поэтому реплей при обновлении пакета избыточен и вреден. -->
        <receiver
            android:exported="false"
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>
        <!-- flutter_local_notifications: обработчик кнопок-действий в уведомлениях. -->
        <receiver
            android:exported="false"
            android:name="com.dexterous.flutterlocalnotifications.ActionBroadcastReceiver" />

        <!-- Домашний виджет Kaizen — task-focused (phase 2) -->
        <receiver
            android:name=".KaizenWidgetProvider"
            android:exported="true"
            android:label="Kaizen Today">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/kaizen_widget_info" />
        </receiver>

        <!-- Второй виджет Kaizen — Kai-дашборд (ретеншн, §3/§10.4 WIDGET.md) -->
        <receiver
            android:name=".KaizenKaiWidgetProvider"
            android:exported="false"
            android:label="Kai">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/kai_widget_info" />
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Видимость сервиса распознавания речи (Android 11+, speech_to_text) -->
        <intent>
            <action android:name="android.speech.RecognitionService"/>
        </intent>
    </queries>
</manifest>
