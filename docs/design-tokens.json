{
  "$schema-note": "Design tokens for Kaizen. Single source of truth for colours, fonts, spacing. Flutter and the landing page must read from here. Animation durations/curves live in /docs/ANIMATIONS.md (the animation source of truth) — the values below mirror its section 0 constants. Exact colours for themes 1-5 come from docs/design/01-color.md; all tokens are confirmed with WCAG contrast ratios.",
  "version": 3,
  "animation": {
    "source_of_truth": "/docs/ANIMATIONS.md",
    "snap_ms": 120,
    "fast_ms": 180,
    "normal_ms": 280,
    "slow_ms": 300,
    "curve_snap": "easeOut",
    "curve_spring": "elasticOut",
    "curve_lift": "easeOutCubic",
    "curve_slide": "easeInOutCubic",
    "note": "Mirrors ANIMATIONS.md section 0 — if they ever differ, ANIMATIONS.md wins. Per-tab character: Today=lift+spring, Plan=lateral, Health=fluid, Diary=calm/slower. All animations must be disableable (MediaQuery.disableAnimations)."
  },
  "spacing": { "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 32, "xxl": 48 },
  "radius": { "sm": 8, "md": 16, "lg": 24, "pill": 999 },
  "font_scale": { "default": 1.0, "contrast": 1.15 },
  "themes": {
    "focus": {
      "label": "Focus (warm dark, default)",
      "mode": "dark",
      "default": true,
      "colors": {
        "bg": "#141009",
        "surface": "#241D11",
        "surface_elevated": "#2E2618",
        "text": "#F6EFE1",
        "text_muted": "#9E9070",
        "text_faint": "#736850",
        "accent": "#D9F24B",
        "accent_muted": "#26290F",
        "ember": "#FF6A3D",
        "success": "#4BAF6F",
        "border": "#3A3020",
        "border_strong": "#524630"
      },
      "semantic": { "important": "#D9F24B", "urgent": "#FF6A3D", "done": "#4BAF6F" },
      "fonts": { "display": "Fraunces", "body": "Hanken Grotesk" }
    },
    "calm": {
      "label": "Calm (low-saturation blue-green)",
      "mode": "dark",
      "colors": {
        "bg": "#11171A",
        "surface": "#18232A",
        "surface_elevated": "#1F2E38",
        "text": "#E8F0F0",
        "text_muted": "#8AA0A0",
        "text_faint": "#617E7E",
        "accent": "#6FB6A3",
        "accent_muted": "#172628",
        "ember": "#E08A6B",
        "success": "#5AB594",
        "border": "#243640",
        "border_strong": "#365060"
      },
      "semantic": { "important": "#6FB6A3", "urgent": "#E08A6B", "done": "#5AB594" },
      "fonts": { "display": "Newsreader", "body": "DM Sans" }
    },
    "black": {
      "label": "Black (OLED full-black)",
      "mode": "dark",
      "colors": {
        "bg": "#000000",
        "surface": "#0E0E0E",
        "surface_elevated": "#161616",
        "text": "#FFFFFF",
        "text_muted": "#8A8A8A",
        "text_faint": "#636363",
        "accent": "#C8FF4D",
        "accent_muted": "#1A1F0A",
        "ember": "#FF6A3D",
        "success": "#4BAF6F",
        "border": "#1C1C1C",
        "border_strong": "#2E2E2E"
      },
      "semantic": { "important": "#C8FF4D", "urgent": "#FF6A3D", "done": "#4BAF6F" },
      "fonts": { "display": "Schibsted Grotesk", "body": "Schibsted Grotesk" }
    },
    "white": {
      "label": "White (clean light)",
      "mode": "light",
      "colors": {
        "bg": "#FFFFFF",
        "surface": "#F5F4F1",
        "surface_elevated": "#ECEAE5",
        "text": "#16130E",
        "text_muted": "#6B675F",
        "text_faint": "#858178",
        "accent": "#2B2A26",
        "accent_muted": "#EDECEA",
        "accent_alt": "#3558E8",
        "ember": "#E5533A",
        "success": "#1A7A3E",
        "border": "#E3E0DA",
        "border_strong": "#C8C4BC"
      },
      "notes": {
        "accent_alt": "Use #3558E8 (not #5B7CFA) wherever accentAlt appears as rendered text or icon. #5B7CFA (old) fails 4.5:1 body text threshold (3.68:1 on bg). #3558E8 passes at 5.66:1. #5B7CFA may only be used as a large badge background with bg/text on top.",
        "accent": "#2B2A26 is near-black ink — the primary accent. accentAlt (#3558E8) is semantic-only (badge/chip indicator)."
      },
      "semantic": { "important": "#3558E8", "urgent": "#E5533A", "done": "#1A7A3E" },
      "fonts": { "display": "Instrument Serif", "body": "Plus Jakarta Sans" }
    },
    "contrast": {
      "label": "Contrast (accessibility, large type)",
      "mode": "dark",
      "colors": {
        "bg": "#000000",
        "surface": "#0A0A0A",
        "surface_elevated": "#141414",
        "text": "#FFFFFF",
        "text_muted": "#D0D0D0",
        "text_faint": "#A0A0A0",
        "accent": "#FFE600",
        "accent_muted": "#2A2600",
        "ember": "#FF5230",
        "success": "#00E5A0",
        "border": "#FFFFFF",
        "border_strong": "#FFFFFF"
      },
      "notes": {
        "_placeholder_resolved": "Contrast palette fully specified and WCAG-verified in docs/design/01-color.md. All pairs pass 4.5:1 for body text. _placeholder flag removed.",
        "type_overrides": "display/headline fontWeight w800, body letterSpacing +0.2, body lineHeight 1.60 — applied in _buildTheme contrastTheme branch in app_theme.dart.",
        "scale": "font_scale.contrast = 1.15 applied via MediaQuery.textScaler in main.dart"
      },
      "semantic": { "important": "#FFE600", "urgent": "#FF5230", "done": "#00E5A0" },
      "fonts": { "display": "Atkinson Hyperlegible", "body": "Atkinson Hyperlegible" }
    }
  }
}
