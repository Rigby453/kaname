{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.rulers": [100],
  "editor.tabSize": 2,
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[dart]": { "editor.defaultFormatter": "Dart-Code.dart-code", "editor.rulers": [80] },
  "[yaml]": { "editor.defaultFormatter": "redhat.vscode-yaml" },
  "[prisma]": { "editor.defaultFormatter": "Prisma.prisma" },
  "files.exclude": { "**/node_modules": true, "**/.dart_tool": true, "**/build": true },
  "search.exclude": { "**/node_modules": true, "**/build": true },
  "yaml.schemas": {
    "https://raw.githubusercontent.com/OAI/OpenAPI-Specification/main/schemas/v3.0/schema.json": "docs/api-spec.yaml"
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "dart.previewFlutterUiGuides": true,
  "files.associations": { "*.env": "dotenv", "*.env.*": "dotenv", "CLAUDE.md": "markdown" },
  "editor.bracketPairColorization.enabled": true,
  "errorLens.enabledDiagnosticLevels": ["error", "warning"]
}
